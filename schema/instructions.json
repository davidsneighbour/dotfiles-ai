  "$id": "https://example.local/schemas/instructions-frontmatter.schema.json",
  "title": "Custom VS Code instruction frontmatter",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "applyTo": {
      "type": "string",
      "description": "Glob pattern that determines when the instruction file applies."
