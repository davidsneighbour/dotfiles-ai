{
  "name": "@davidsneighbour/dotfiles-ai",
  "description": "",
  "version": "0.4.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidsneighbour/dotfiles-ai.git"
  },
  "author": "Patrick Kollitsch <davidsneighbourdev+gh@gmail.com>",
  "bugs": {
    "url": "https://github.com/davidsneighbour/dotfiles-ai/issues"
  },
  "homepage": "https://github.com/davidsneighbour/dotfiles-ai#readme",
  "keywords": [],
  "dependencies": {
    "cspell": "9.7.0",
    "undici-types": "7.22.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "10.0.6",
    "@types/node": "25.5.0",
    "release-it": "19.2.4"
  },
  "type": "module",
  "scripts": {
    "release": "release-it",
    "release:minor": "release-it --increment minor",
    "format:prompts": "npx prettier --write \"prompts/**/*.prompt.md\"",
    "lint:prompts": "markdownlint-cli2 \"prompts/**/*.prompt.md\""
  },
  "release-it": {
    "npm": {
      "publish": false
    },
    "git": {
      "tagName": "v${version}",
      "commitMessage": "chore(release): v${version}",
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commit": true,
      "tag": true,
      "push": true
    },
    "github": {
      "release": true,
      "web": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits",
        "infile": "CHANGELOG.md"
      }
    }
  }
}
