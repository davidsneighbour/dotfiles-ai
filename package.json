{
  "name": "@davidsneighbour/copailot",
  "description": "",
  "version": "0.0.4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidsneighbour/copailot.git"
  },
  "author": "Patrick Kollitsch <davidsneighbourdev+gh@gmail.com>",
  "bugs": {
    "url": "https://github.com/davidsneighbour/copailot/issues"
  },
  "homepage": "https://github.com/davidsneighbour/copailot#readme",
  "keywords": [],
  "dependencies": {
    "undici-types": "7.22.0"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "release-it": "^17.6.0",
    "@release-it/conventional-changelog": "^8.0.2"
  },
  "type": "module",
  "scripts": {
    "release": "release-it --ci",
    "release:minor": "release-it --ci --increment minor",
    "format:prompts": "npx prettier --write \"prompts/**/*.prompt.md\"",
    "lint:prompts": "markdownlint-cli2 \"prompts/**/*.prompt.md\""
  },
  "release-it": {
    "git": {
      "tagName": "v${version}",
      "commitMessage": "chore(release): v${version}",
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commit": true,
      "tag": true,
      "push": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits",
        "infile": "CHANGELOG.md"
      }
    }
  }
}
